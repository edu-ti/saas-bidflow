# BidFlow - Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores

# ==========================================
# BACKEND LARAVEL
# ==========================================
APP_NAME=BidFlow
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=bidflow
DB_USERNAME=postgres
DB_PASSWORD=secret

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ==========================================
# RPA ROBOT
# ==========================================
BIDFLOW_API_TOKEN=
BIDFLOW_API_URL=http://localhost:8000/api
BIDFLOW_SEARCH_TERM=Material Hospitalar
BIDFLOW_OPPORTUNITY_ID=1
BIDFLOW_HEADLESS=true
BIDFLOW_TIMEOUT=30
BIDFLOW_DOWNLOAD_DIR=./downloads
BIDFLOW_MAX_RETRIES=3
BIDFLOW_RETRY_DELAY=5

# ==========================================
# TELEGRAM BOT
# ==========================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ==========================================
# WEBSOCKETS (LARAVEL REVERB)
# ==========================================
BROADCAST_DRIVER=reverb
REVERB_APP_ID=your-app-id
REVERB_APP_KEY=your-app-key
REVERB_APP_SECRET=your-app-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

# ==========================================
# FRONTEND
# ==========================================
VITE_API_URL=http://localhost:8000/api
VITE_WS_URL=ws://localhost:8080
