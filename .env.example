# GC Representações & Serviços - BidFlow
# ==========================================
# Copie este arquivo para .env e preencha os valores

# ==========================================
# APLICAÇÃO
# ==========================================
APP_NAME="GC Representações & Serviços"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://seudominio.com.br

# ==========================================
# BANCO DE DADOS (PostgreSQL)
# ==========================================
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=bidflow
DB_USERNAME=postgres
DB_PASSWORD=suasenhaSegura123

# ==========================================
# REDIS (Filas e Cache)
# ==========================================
REDIS_HOST=redis
REDIS_PASSWORD=
REDIS_PORT=6379
QUEUE_CONNECTION=redis
CACHE_STORE=redis
SESSION_DRIVER=redis

# ==========================================
# AUTENTICAÇÃO
# ==========================================
SANCTUM_STATE_DURATION=20160
BROADCAST_DRIVER=reverb
SESSION_DOMAIN=.seudominio.com.br

# ==========================================
# WEBSOCKETS (Laravel Reverb)
# ==========================================
REVERB_APP_ID=your-reverb-app-id
REVERB_APP_KEY=your-reverb-app-key
REVERB_APP_SECRET=your-reverb-app-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=https

# ==========================================
# E-MAIL
# ==========================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@seudominio.com.br
MAIL_FROM_NAME="${APP_NAME}"

# ==========================================
# RPA ROBOT
# ==========================================
BIDFLOW_API_TOKEN=seutoken123
BIDFLOW_API_URL=${APP_URL}/api
BIDFLOW_SEARCH_TERM=Material Hospitalar
BIDFLOW_OPPORTUNITY_ID=1
BIDFLOW_HEADLESS=true
BIDFLOW_TIMEOUT=30
BIDFLOW_DOWNLOAD_DIR=./downloads
BIDFLOW_MAX_RETRIES=3
BIDFLOW_RETRY_DELAY=5

# ==========================================
# TELEGRAM BOT
# ==========================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ==========================================
# FRONTEND (React/Vite)
# ==========================================
VITE_API_URL=${APP_URL}/api
VITE_WS_URL=wss://localhost:8080

# ==========================================
# PORTA DO NGINX
# ==========================================
HTTP_PORT=80
HTTPS_PORT=443

# ==========================================
# LOGS
# ==========================================
LOG_CHANNEL=daily
LOG_LEVEL=warning

# ==========================================
# SEGURANÇA
# ==========================================
APP_TRUST_PROXIES=*
FORCE_HTTPS=true